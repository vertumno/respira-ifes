/* audio-engine.js — sons ambiente e sinais de fase via Web Audio API */
(function (global) {
  'use strict';

  let audioCtx    = null;
  let ambientNode = null;
  let ambientGain = null;
  let currentSound = 'none';
  let phaseSoundsEnabled = true;

  function getCtx() {
    if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    if (audioCtx.state === 'suspended') audioCtx.resume();
    return audioCtx;
  }

  // ---- Generators ----

  function makeBrownNoise(ctx) {
    const buf = ctx.createBuffer(1, 2 * ctx.sampleRate, ctx.sampleRate);
    const d = buf.getChannelData(0);
    let last = 0;
    for (let i = 0; i < d.length; i++) {
      const w = Math.random() * 2 - 1;
      d[i] = (last + 0.02 * w) / 1.02;
      last = d[i];
      d[i] *= 3.5;
    }
    const src = ctx.createBufferSource();
    src.buffer = buf; src.loop = true;
    return src;
  }

  function makeFilteredNoise(ctx, type, freq, q, modPeriod, modAmp, gain) {
    const buf = ctx.createBuffer(2, 2 * ctx.sampleRate, ctx.sampleRate);
    for (let ch = 0; ch < 2; ch++) {
      const d = buf.getChannelData(ch);
      let last = 0;
      for (let i = 0; i < d.length; i++) {
        const w = Math.random() * 2 - 1;
        d[i] = (last + 0.03 * w) / 1.03;
        last = d[i];
        d[i] *= (1 + modAmp * Math.sin(i / (ctx.sampleRate * modPeriod + ch * 200)));
        d[i] *= gain;
      }
    }
    const src = ctx.createBufferSource();
    src.buffer = buf; src.loop = true;
    const filt = ctx.createBiquadFilter();
    filt.type = type; filt.frequency.value = freq; filt.Q.value = q;
    src.connect(filt);
    return {
      start: (t) => src.start(t),
      stop:  (t) => { try { src.stop(t); } catch(e) {} },
      connect: (dest) => filt.connect(dest),
    };
  }

  // ---- Public API ----

  function startAmbient(type) {
    stopAmbient();
    if (type === 'none') { currentSound = 'none'; return; }
    const ctx = getCtx();
    ambientGain = ctx.createGain();
    const vol = parseFloat(document.getElementById('volumeSlider')?.value ?? 40) / 100 * 0.5;
    ambientGain.gain.value = vol;
    ambientGain.connect(ctx.destination);

    if (type === 'brown') {
      ambientNode = makeBrownNoise(ctx);
      ambientNode.connect(ambientGain);
      ambientNode.start(0);
    } else if (type === 'water') {
      ambientNode = makeFilteredNoise(ctx, 'lowpass', 800, 0.5, 0.8, 0.3, 3);
      ambientNode.connect(ambientGain);
      ambientNode.start(0);
    } else if (type === 'wind') {
      ambientNode = makeFilteredNoise(ctx, 'bandpass', 400, 0.3, 3.5, 0.8, 2.5);
      ambientNode.connect(ambientGain);
      ambientNode.start(0);
    }
    currentSound = type;
  }

  function stopAmbient() {
    if (ambientNode) {
      if (typeof ambientNode.stop === 'function') { try { ambientNode.stop(0); } catch(e) {} }
      ambientNode = null;
    }
    ambientGain = null;
  }

  function fadeOutAmbient(duration) {
    if (!ambientGain || !audioCtx) { stopAmbient(); return; }
    const now = audioCtx.currentTime;
    ambientGain.gain.cancelScheduledValues(now);
    ambientGain.gain.setValueAtTime(ambientGain.gain.value, now);
    ambientGain.gain.linearRampToValueAtTime(0, now + duration);
    setTimeout(() => stopAmbient(), (duration + 0.15) * 1000);
  }

  function setVolume(v) {
    if (ambientGain) ambientGain.gain.value = parseFloat(v) / 100 * 0.5;
  }

  function playTone(freq, dur, type = 'sine') {
    if (!phaseSoundsEnabled) return;
    const ctx = getCtx();
    const osc  = ctx.createOscillator();
    const gain = ctx.createGain();
    osc.type = type; osc.frequency.value = freq;
    gain.gain.value = 0;
    osc.connect(gain); gain.connect(ctx.destination);
    const t = ctx.currentTime;
    gain.gain.linearRampToValueAtTime(0.12, t + 0.08);
    gain.gain.linearRampToValueAtTime(0, t + dur);
    osc.start(t); osc.stop(t + dur);
  }

  function setPhaseSounds(enabled) { phaseSoundsEnabled = enabled; }

  function playInhale()   { playTone(528, 0.4); }
  function playExhale()   { playTone(396, 0.5); }
  function playHold()     { playTone(440, 0.2, 'triangle'); }
  function playComplete() {
    playTone(528, 0.3);
    setTimeout(() => playTone(660, 0.3), 200);
    setTimeout(() => playTone(792, 0.5), 400);
  }

  // ---- Wire up UI controls ----
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.sound-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.sound-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const sound = btn.dataset.sound;
        const vc = document.getElementById('volumeControl');
        if (vc) vc.style.display = sound === 'none' ? 'none' : 'flex';
        startAmbient(sound);
      });
    });

    document.getElementById('volumeSlider')?.addEventListener('input', e => setVolume(e.target.value));

    const psBtn = document.getElementById('phaseSoundToggle');
    psBtn?.addEventListener('click', () => {
      phaseSoundsEnabled = !phaseSoundsEnabled;
      psBtn.classList.toggle('active', phaseSoundsEnabled);
    });
  });

  // Expose to breathing engine
  global.RespireAudio = { startAmbient, stopAmbient, fadeOutAmbient, setVolume, playInhale, playExhale, playHold, playComplete, setPhaseSounds };

})(window);
